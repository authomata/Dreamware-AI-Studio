# Supabase — get these from Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # server-only, never expose to client

# Upload limits
# Max file size accepted by /api/upload/sign. Must match the Supabase Storage
# bucket limit set in Dashboard. Supabase Free = 50 MB, Pro = up to 5 GB.
NEXT_PUBLIC_MAX_UPLOAD_SIZE_MB=50

# Resend — transactional emails (Phase 6)
# Get API key from https://resend.com/api-keys
# Domain must be verified in Resend Dashboard before sending.
# If not set, email sending is silently skipped (invitations still work via manual link).
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=notificaciones@dreamware.cl

# App base URL — used for invitation links in emails
NEXT_PUBLIC_APP_URL=https://lab.dreamware.studio
